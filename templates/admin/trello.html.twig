{% extends 'base.html.twig' %}

{% block title %} Gestion Candidat - Admin {% endblock %}

{% block body %}
    <div class="containe-fluid mt-4">
        <h1 class="mb-4 text-center">Gestion des candidats</h1>
        <div class="mb-4 text-center">
            <input type="text" id="newColonneTitre" class="form-control d-inline-block w-25" placeholder="Nom de la colonne">
            <button id="addColonneBtn" class="btn btn-success ms-2">Ajouter une colonne</button>
        </div>
        <div id="columns-wrapper" style="overflow-x: auto;">
            <div id="columns-container" class="d-flex flex-row mt-4" style="min-width: max-content; height: 70vh;"> 
                {% for colonne in colonnes %}
                <div class="colonne-item me-3" style="min-width:300px; height: 100%;" data-colonne-id="{{ colonne.id }}">
                    <div class="card h-100 d-flex flex-column">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">    
                            <span class="colonne-titre">{{ colonne.titre }}</span>
                            <div class="d-flex align-items-center gap-1">
                                <button class="btn btn-sm btn-light edit-colonne-btn p-1" data-colonne-id="{{ colonne.id }}" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-danger delete-colonne-btn p-1" data-colonne-id="{{ colonne.id }}" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        {# Ne pas supprimer "data-carte-id", car il permet de sauvegarder la positions des cartes et de les deplacer #}      
                        <ul class="list-group list-group-flush cards flex-grow-1 overflow-auto" 
                            data-colonne-id="{{ colonne.id }}"
                            style="max-height: 100%;">
                            {% set cartes = colonne.colonne|sort((a, b) => a.position <=> b.position) %}
                            {% if cartes|length > 0 %}
                                {% for carte in cartes %}
                                    <li class="list-group-item card-item"
                                        data-carte-id="{{ carte.id }}"
                                        data-user-id="{{ carte.utilisateur.id }}"
                                        data-nom="{{ carte.utilisateur.nom }}"
                                        data-prenom="{{ carte.utilisateur.prenom }}"
                                        data-email="{{ carte.utilisateur.email }}"
                                        data-telephone="{{ carte.utilisateur.telephone }}"
                                        data-pays="{{ carte.utilisateur.pays }}"
                                        data-ville="{{ carte.utilisateur.ville }}"
                                        data-cv="{{ carte.utilisateur.cv }}"
                                        data-linkedin="{{ carte.utilisateur.linkedin }}"
                                        data-sexe="{{ carte.utilisateur.sexe }}"
                                        data-datenaissance="{{ carte.utilisateur.datedenaissance ? carte.utilisateur.datedenaissance|date('d/m/Y') : '' }}"
                                        data-besoins='{{ carte.utilisateur.besoin|json_encode }}'
                                        data-recherche='{{ carte.utilisateur.recherche|json_encode }}'
                                        data-description="{{ carte.utilisateur.description }}">

                                        {# Ce qui est affiché sur la carte #}
                                        <strong class="d-block mb-1">
                                            {{ carte.utilisateur.nom }} {{ carte.utilisateur.prenom }}
                                        </strong>
                                        {% if carte.utilisateur.besoin is not empty %}
                                            <h6>Besoin :</h6>
                                            <ul class="mb-1 ps-3">
                                                {% for besoin in carte.utilisateur.besoin %}
                                                    <li class="small text-dark">
                                                        {{ besoin }}
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                        {% if carte.utilisateur.recherche is not empty %}
                                            <h6>Recherche :</h6>
                                            <ul class="mb-0 ps-3">
                                                {% for recherche in carte.utilisateur.recherche %}
                                                    <li class="small text-muted">
                                                        {{ recherche }}
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                                <li class="list-group-item text-muted no-card" style="display:none;">Aucune carte</li>
                            {% else %}
                                <li class="list-group-item text-muted no-card">Aucune carte</li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Modal utilisateur -->
    <div class="modal fade" id="userModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Détails utilisateur</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <p><strong>Nom :</strong> <span id="modalNom"></span></p>
            <p><strong>Prénom :</strong> <span id="modalPrenom"></span></p>
            <p><strong>Email :</strong> <span id="modalEmail"></span></p>
            <p><strong>Téléphone :</strong> <span id="modalTelephone"></span></p>
            <p><strong>Pays :</strong> <span id="modalPays"></span></p>
            <p><strong>Ville :</strong> <span id="modalVille"></span></p>
            <p><strong>Sexe :</strong> <span id="modalSexe"></span></p>
            <p><strong>Date de naissance :</strong> <span id="modalDateNaissance"></span></p>
            <p><strong>CV :</strong> <a id="modalCv" href="#" download>Télécharger le CV</a></p>
            <p><strong>LinkedIn :</strong> <a id="modalLinkedin" href="#" target="_blank"></a></p>
            <p><strong>Besoins :</strong></p>
            <ul id="modalBesoins"></ul>

            <p><strong>Recherche :</strong></p>
            <ul id="modalRecherche"></ul>

            <p><strong>Description :</strong></p>
            <p id="modalDescription"></p>
          </div>
          <div class="modal-footer">
            <button id="deleteCardOnly" class="btn btn-warning">Supprimer la carte uniquement</button>
            <button id="deleteUserAndCard" class="btn btn-danger">Supprimer la carte et l'utilisateur</button>
            <button class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
          </div>
        </div>
      </div>
    </div>

    <!-- SortableJS -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const lists = document.querySelectorAll('.cards');

        // VARIABLES POUR SUPPRESSION
        let currentCarteId = null;
        let currentUserId = null;

        lists.forEach(list => {
            new Sortable(list, {
                group: 'shared',
                animation: 150,
                onStart: function(evt) {
                    evt.item.style.cursor = 'grabbing';
                },
                onEnd: function (evt) {
                    const colonne = evt.to;
                    const colonneId = colonne.dataset.colonneId;

                    const cartes = Array.from(colonne.querySelectorAll('.card-item'));

                    const positions = cartes.map((carte, index) => ({
                        carteId: carte.dataset.carteId,
                        position: index + 1
                    }));

                    fetch('{{ path("Admin_deplacementcartetrello")}}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-CSRF-TOKEN': '{{ csrf_token("Admin_deplacementcartetrello") }}'
                        },
                        body: JSON.stringify({
                            colonneId: colonneId,
                            positions: positions
                        })
                    });

                    const noCard = colonne.querySelector('.no-card');
                    if (cartes.length === 0) {
                        noCard.style.display = 'block';
                    } else {
                        noCard.style.display = 'none';
                    }

                    evt.item.style.cursor = 'grab';
                }
            });
        });

        // =========================
        // DRAG & DROP COLONNES
        // =========================
        const container = document.getElementById('columns-container');

        new Sortable(container, {
            animation: 150,
            draggable: '.colonne-item',
            ghostClass: 'bg-light',
            onStart: function(evt) {
                    evt.item.style.cursor = 'grabbing';
                },
            onEnd: function () {

                const colonnes = Array.from(container.querySelectorAll('.colonne-item'));

                const positions = colonnes.map((col, index) => ({
                    colonneId: col.dataset.colonneId,
                    position: index + 1
                }));

                fetch('{{ path("update_position_colonnes") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        positions: positions
                    })
                });
            }
        });


        const allCards = document.querySelectorAll('.card-item');
        allCards.forEach(carte => {
            carte.style.cursor = 'grab';
        });

        // CLIC SUR CARTE → MODAL
        allCards.forEach(carte => {
            carte.addEventListener('click', function () {

                // STOCKAGE DES IDS POUR SUPPRESSION
                currentCarteId = this.dataset.carteId;
                currentUserId = this.dataset.userId;

                document.getElementById('modalNom').textContent = this.dataset.nom;
                document.getElementById('modalPrenom').textContent = this.dataset.prenom;
                document.getElementById('modalEmail').textContent = this.dataset.email;
                document.getElementById('modalTelephone').textContent = this.dataset.telephone;
                document.getElementById('modalPays').textContent = this.dataset.pays;
                document.getElementById('modalVille').textContent = this.dataset.ville;
                document.getElementById('modalSexe').textContent = this.dataset.sexe;
                document.getElementById('modalDateNaissance').textContent = this.dataset.datenaissance;

                const cvLink = document.getElementById('modalCv');
                if (this.dataset.cv) {
                    cvLink.href = '/utilisateur/admin/trello/download/cv/' + this.dataset.cv;
                    cvLink.style.display = 'inline';
                } else {
                    cvLink.style.display = 'none';
                }

                const linkedinLink = document.getElementById('modalLinkedin');
                if (this.dataset.linkedin) {
                    linkedinLink.href = this.dataset.linkedin;
                    linkedinLink.textContent = this.dataset.linkedin;
                    linkedinLink.style.display = 'inline';
                } else {
                    linkedinLink.style.display = 'none';
                }

                let url = this.dataset.linkedin;
                if (!url.startsWith('http')) {
                    url = 'https://' + url;
                }
                linkedinLink.href = url;

                document.getElementById('modalDescription').textContent = this.dataset.description;

                // JSON → liste
                const besoins = JSON.parse(this.dataset.besoins || "[]");
                const recherche = JSON.parse(this.dataset.recherche || "[]");

                const besoinsList = document.getElementById('modalBesoins');
                const rechercheList = document.getElementById('modalRecherche');

                besoinsList.innerHTML = "";
                rechercheList.innerHTML = "";

                besoins.forEach(item => {
                    const li = document.createElement('li');
                    li.textContent = item;
                    besoinsList.appendChild(li);
                });

                recherche.forEach(item => {
                    const li = document.createElement('li');
                    li.textContent = item;
                    rechercheList.appendChild(li);
                });

                const modal = new bootstrap.Modal(document.getElementById('userModal'));
                modal.show();
            });
        });

        // =========================
        // SUPPRESSION CARTE UNIQUEMENT
        // =========================
        document.getElementById('deleteCardOnly').addEventListener('click', function () {

            if (!confirm('Supprimer cette carte ?')) return;

            fetch('/utilisateur/admin/trello/delete-card', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    carteId: currentCarteId
                })
            })
            .then(() => location.reload());
        });

        // =========================
        // SUPPRESSION USER + CARTE
        // =========================
        document.getElementById('deleteUserAndCard').addEventListener('click', function () {

            if (!confirm('ATTENTION ! Vous allez supprimer la carte ET l\'utilisateur associé ! Êtes vous sûr de continuer ?')) return;

            fetch('/utilisateur/admin/trello/delete-user', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    userId: currentUserId
                })
            })
            .then(() => location.reload());
        });

        // Modifier le nom de la colonne
        document.addEventListener('click', function(e) {
            const editBtn = e.target.closest('.edit-colonne-btn');
            if (editBtn) {

                const colonneId = editBtn.dataset.colonneId;
                const header = editBtn.closest('.card-header');
                const titreElement = header.querySelector('.colonne-titre');

                const titreActuel = titreElement.textContent;

                const nouveauTitre = prompt('Modifier le titre :', titreActuel);
                if (!nouveauTitre) return;

                fetch('{{ path("modifier_colonne") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        colonneId: colonneId,
                        titre: nouveauTitre
                    })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        titreElement.textContent = data.nouveauTitre;
                    }
                });
            }
        });

        // =========================
        // SUPPRESSION COLONNE
        // =========================
        document.addEventListener('click', function(e) {

            const deleteBtn = e.target.closest('.delete-colonne-btn');
            if (!deleteBtn) return;

            if (!confirm('Supprimer cette colonne et toutes ses cartes ?')) return;

            const colonneId = deleteBtn.dataset.colonneId;

            // IMPORTANT : on cible uniquement le vrai conteneur colonne
            const colonneElement = deleteBtn.closest('.colonne-item');

            fetch('{{ path("delete_colonne") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    colonneId: colonneId
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {

                    // Suppression immédiate dans le DOM
                    if (colonneElement) {
                        colonneElement.remove();
                    }

                } else {
                    alert('Erreur lors de la suppression');
                }
            })
            .catch(() => {
                alert('Erreur serveur');
            });

        });

        // =========================
        // AJOUT COLONNE
        // =========================
        document.getElementById('addColonneBtn').addEventListener('click', function () {

            const input = document.getElementById('newColonneTitre');
            const titre = input.value.trim();

            if (!titre) {
                alert('Veuillez entrer un titre');
                return;
            }

            fetch('{{ path("add_colonne") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    titre: titre
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {

                    // Création HTML de la nouvelle colonne
                    const newCol = document.createElement('div');
                    newCol.className = 'colonne-item me-3';
                    newCol.style.minWidth = '300px';
                    newCol.style.height = '100%';
                    newCol.innerHTML = `
                        <div class="card h-100 d-flex flex-column">
                            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">    
                                <span class="colonne-titre">${data.titre}</span>
                                <div class="d-flex align-items-center gap-1">
                                    <button class="btn btn-sm btn-light edit-colonne-btn p-1" data-colonne-id="${data.id}" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger delete-colonne-btn p-1" data-colonne-id="${data.id}" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                            <ul class="list-group list-group-flush cards flex-grow-1" data-colonne-id="${data.id}">
                                <li class="list-group-item text-muted no-card">Aucune carte</li>
                            </ul>
                        </div>
                    `;

                    // Ajouter à la ligne des colonnes
                    document.getElementById('columns-container').appendChild(newCol);

                    // Pour que les cartes dans la nouvelle colonne soit deplacable
                    const newList = newCol.querySelector('.cards');
                    new Sortable(newList, {
                        group: 'shared',
                        animation: 150
                    });

                    // Reset input
                    input.value = '';

                } else {
                    alert('Erreur : ' + (data.message || 'Impossible d\'ajouter'));
                }
            });
        });
    });
    </script>
{% endblock %}