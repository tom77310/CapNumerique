{% extends 'base.html.twig' %}

{% block title %}Inscription Candidat {% endblock %}
{% block page_title %} Inscription Candidat {% endblock %}

{% block body %}
    <div class="container mt-5">
        <a href="{{ path('Utilisateur_choixinscription')}}">Retour</a>
        <h2 class="text-center mb-5 border-bottom pb-2">Inscription Candidats</h2>
        {{ form_start(formcandidat) }}
        <div class="row">
            {# Colonne de gauche #}
            <div class="col-md-6">
                <h4 class="border-bottom pb-2 mb-4">Informations Personnelles</h4>
                <div class="mb-3">
                    <label class="fw-bold">Sexe</label>
                    {% for child in formcandidat.Sexe %}
                        <div class="form-check form-check-inline">
                            {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>
                    {% endfor %}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.Nom) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.Prenom) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.email) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.Telephone) }}
                </div>
                <div class="mb-3">
                    <label class="">Date de naissance</label>
                    {{ form_widget(formcandidat.datedenaissance) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.Pays) }}
                </div>
                <div class="mb-3">
                    {{ form_row(formcandidat.Ville) }}
                </div>
                <div class="mb-3">
                    <label class="">Mot de passe</label>
                    {{ form_widget(formcandidat.password) }}
                </div>
            </div>
            <div class="col-md-6">
                <h4 class="border-bottom pb-2 mb-4">Informations Professionnelle</h4>
                <div class="form-check mb-2">
                    <label class="fw-bold">Votre Besoin</label>
                    {{ form_widget(formcandidat.besoin) }}
                </div>
                <div class="form-check mb-2" id="bloc-recherche" style="display: none;">
                    <label class="fw-bold mt-3">Votre Recherche</label>
                    {{ form_widget(formcandidat.recherche) }}
                </div>
                <div class="mb-2 mt-4">
                    <label class="fw-bold">Veuillez Insérer le lien vers votre profil linkedin </label>
                    {{ form_widget(formcandidat.linkedin) }}
                </div>
                <div class="mb-4 mt-3">
                    <label class="fw-bold">Insérer votre CV</label>
                    {{ form_widget(formcandidat.CV) }}
                </div>
                <div class="mt-3">
                    <label class="fw-bold">Vous pouvez exposez vos motivations (facultatif)</label>
                    {{ form_widget(formcandidat.description) }}
                </div>
                <div class="mt-3">
                    <label class="fw-bold">Acceptez les politiques de confidentialité (obligatoire)</label>
                    {{ form_widget(formcandidat.accepterConfidentialite) }}
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            {{ form_row(formcandidat.submit) }}
        </div>
        {{ form_end(formcandidat) }}
    </div>

    {% block javascript %}
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const besoinInputs = document.querySelectorAll('[name="form_candidat[besoin][]"]');
                const blocRecherche = document.getElementById('bloc-recherche');

                function toggleRecherche() {
                    let show = false;

                    besoinInputs.forEach(input => {
                        if (input.checked && input.value === 'orientation') {
                            show = true;
                        }
                    });

                    blocRecherche.style.display = show ? 'block' : 'none';
                }

                // Vérifie au chargement (si formulaire pré-rempli)
                toggleRecherche();

                // Ajoute l'écoute sur chaque checkbox
                besoinInputs.forEach(input => {
                    input.addEventListener('change', toggleRecherche);
                });
            });
        </script>
    {% endblock %}
{% endblock %}
