{% extends 'base.html.twig' %}

{% block title %} Choix de l'Inscription {% endblock %}
{% block page_title %} Choix Inscription {% endblock %}

{% block body %}

    <div class="container mt-5 mb-5">
        <h2 class="text-center mb-5">
            Choississez votre type de compte :
        </h2>
        <div class="row justify-content-center g-4">
            {# Inscription Candidat #}
            <div class="col-md-4">
                <div class="card shadow text-center p-4 h-100">
                    <div class="mb-3">
                        <i class="bi bi-person-fill" style="font-size: 50px;"></i>
                    </div>
                    <h4 class="mb-3">Inscription Candidat</h4>
                    <p class="text-muted">
                        Recherchez un emploi, un stage ou une alternance et postulez facilement
                    </p>
                    <a href="{{ path('Utilisateur_inscriptioncandidat')}}" 
                        class="btn btn-dark mt-3">
                        S'inscrire en tant que candidat    
                    </a>
                </div>
            </div>
            {# Inscription Entreprises #}
            <div class="col-md-4">
                <div class="card shadow text-center p-4 h-100">
                    <div class="mb-3">
                        <i class="bi bi-building" style="font-size: 50px;"></i>
                    </div>
                    <h4 class="mb-3">
                        Inscription Entreprises
                    </h4>
                    <p class="text-muted">
                        Publiez vos offres d'emploi et trouvez les meilleurs candidats
                    </p>
                    <a href="{{ path('Utilisateur_inscriptionentreprise')}}" 
                        class="btn btn-outline-dark mt-3">
                            S'inscrire en tant qu'entreprise
                    </a>
                </div>
            </div>
        </div>
    </div>

{% endblock %}